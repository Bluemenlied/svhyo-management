# ============================================
# PROJECT SPECIFIC
# ============================================
# Database is now tracked - removed from ignore

# Public static (if generated)
public_static/
!public_static/.gitkeep

# Backup files
*.bak
*.backup
backup_*.sql
backup_*.db

# Batch files (keep but track if needed)
# Install.bat
# Start.bat
# But exclude their generated outputs
*.out
*.err

# Temp files
*.tmp
*.temp
temp/
tmp/

# ============================================
# RENDER DEPLOYMENT (optional)
# ============================================
# render.yaml is needed for deployment!
# !render.yaml

# If you have local deployment scripts
deploy_*.sh
deploy_*.bat